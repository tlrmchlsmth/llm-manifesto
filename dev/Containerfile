ARG BASE_IMAGE
FROM ${BASE_IMAGE}

USER root

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update -y \
    && apt-get install -y --no-install-recommends ccache \
    && rm -rf /var/lib/apt/lists/*

# ccache: disable hash_dir since uv builds in random temp dirs
RUN echo "hash_dir = false" > /etc/ccache.conf

# Install dotfiles (zsh, tmux, neovim, fzf, etc.)
RUN git clone https://github.com/tlrmchlsmth/dotfiles /root/.dotfiles \
    && cd /root/.dotfiles && bash install.sh

ENV TORCH_CUDA_ARCH_LIST="9.0a;10.0+PTX" \
    UV_LINK_MODE=copy \
    UV_HTTP_TIMEOUT=500

CMD ["sleep", "infinity"]
